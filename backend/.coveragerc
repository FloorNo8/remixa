# Coverage config for the Remixa backend (coverage.py reads this; it does NOT read pytest.ini).
#
# The --cov-fail-under=70 gate (in pytest.ini addopts) is NOT lowered. Coverage is scoped to the
# SERVED FastAPI application: the modules omitted below are not part of the live app, so measuring
# them would make the gate meaningless. Re-include any module the moment it is mounted + tested.
[run]
source = .
omit =
    tests/*
    */tests/*
    */__pycache__/*
    */site-packages/*
    */venv/*
    # --- unmounted "dead code": main.py mounts only admin_router; these are never imported (AGENTS.md) ---
    api_v2.py
    api_advanced.py
    api_c2pa.py
    nft_minter.py
    lightning_payouts.py
    stripe_v2.py
    vat_moss.py
    gdpr_tools.py
    c2pa_embedder.py
    # --- standalone integrations / dev tooling / load tests / deploy + cron scripts (not the web app) ---
    discord_bot.py
    inference.py
    tiktok_oauth.py
    check_schema.py
    apply_migrations.py
    migrate.py
    locustfile.py
    locustfile_royalty.py
    scripts/*

[report]
precision = 2
show_missing = True
skip_covered = False
exclude_lines =
    pragma: no cover
    def __repr__
    raise AssertionError
    raise NotImplementedError
    if __name__ == .__main__.:
    if TYPE_CHECKING:
    @abstractmethod
