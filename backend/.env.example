# EU TikTok Sound Lab - Environment Configuration
# Copy this file to .env and fill in your actual values

# ============================================================================
# DATABASE
# ============================================================================
DATABASE_URL=postgresql://eu_sound_lab_user:your_password@localhost:5432/eu_sound_lab
DB_PASSWORD=your_secure_password_here

# ============================================================================
# AUTHENTICATION
# ============================================================================
JWT_SECRET=your_jwt_secret_key_here_min_32_chars
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# Clerk (for Next.js frontend)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# ============================================================================
# STRIPE PAYMENT PROCESSING
# ============================================================================
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Product IDs
STRIPE_PRODUCT_PRO=prod_...
STRIPE_PRODUCT_BUSINESS=prod_...

# ============================================================================
# STORAGE (S3-compatible)
# ============================================================================
STORAGE_URL=https://storage.eu-sound-lab.com
STORAGE_BUCKET=eu-sound-lab-audio
STORAGE_REGION=eu-central-1
STORAGE_ACCESS_KEY=your_access_key
STORAGE_SECRET_KEY=your_secret_key

# ============================================================================
# AI MODEL INFERENCE
# ============================================================================
# Local GPU
CUDA_VISIBLE_DEVICES=0
MODEL_PATH=/models/musicgen-stereo-medium

# OR Modal.com (serverless GPU)
MODAL_TOKEN_ID=your_modal_token_id
MODAL_TOKEN_SECRET=your_modal_token_secret

# OR Replicate
REPLICATE_API_TOKEN=r8_...

# ============================================================================
# TIKTOK INTEGRATION
# ============================================================================
TIKTOK_CLIENT_KEY=your_tiktok_client_key
TIKTOK_CLIENT_SECRET=your_tiktok_client_secret
TIKTOK_REDIRECT_URI=https://eu-sound-lab.com/auth/tiktok/callback

# ============================================================================
# VAT MOSS
# ============================================================================
VAT_NUMBER=DK12345678
VAT_MOSS_FILING_EMAIL=vat@eu-sound-lab.com

# ============================================================================
# MONITORING & LOGGING
# ============================================================================
SENTRY_DSN=https://...@sentry.io/...
LOG_LEVEL=INFO

# ============================================================================
# REDIS (Rate Limiting & Caching)
# ============================================================================
REDIS_URL=redis://localhost:6379/0

# ============================================================================
# ENVIRONMENT
# ============================================================================
ENVIRONMENT=production
DEBUG=false
ALLOWED_ORIGINS=https://eu-sound-lab.com,https://www.eu-sound-lab.com

# ============================================================================
# FRONTEND (Next.js)
# ============================================================================
NEXT_PUBLIC_API_URL=https://api.eu-sound-lab.com
NEXT_PUBLIC_CDN_URL=https://cdn.eu-sound-lab.com
NEXT_PUBLIC_SITE_URL=https://eu-sound-lab.com

# ============================================================================
# EMAIL (Optional - for notifications)
# ============================================================================
SMTP_HOST=smtp.eu.mailgun.org
SMTP_PORT=587
SMTP_USER=postmaster@eu-sound-lab.com
SMTP_PASSWORD=your_smtp_password
FROM_EMAIL=noreply@eu-sound-lab.com

# ============================================================================
# MAXMIND GEOLOCATION (for VAT location proof)
# ============================================================================
MAXMIND_LICENSE_KEY=your_maxmind_license_key
MAXMIND_ACCOUNT_ID=your_maxmind_account_id
